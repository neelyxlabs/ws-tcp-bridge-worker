{
  "name": "@neelyxlabs/ws-tcp-bridge-worker",
  "version": "0.1.0",
  "description": "Generic WebSocket-to-TCP bridge as a Cloudflare Worker. HMAC-signed URL + destination allowlist. Protocol-agnostic.",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "wrangler dev",
    "deploy:staging": "wrangler deploy --env staging",
    "deploy:prod": "wrangler deploy --env production",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "@cloudflare/vitest-pool-workers": "^0.5.0",
    "@cloudflare/workers-types": "^4.20260401.0",
    "typescript": "^5.5.0",
    "vitest": "^2.1.0",
    "wrangler": "^3.90.0"
  },
  "dependencies": {
    "jose": "^6.2.2"
  }
}
